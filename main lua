function showMainLayout()
  layout = {
    LinearLayout,
    orientation = "vertical",
    layout_width = "match_parent",
    layout_height = "match_parent",
    {
      LinearLayout,
      orientation = "horizontal",
      layout_width = "match_parent",
      layout_height = "wrap_content",
      background = "#3F51B5",
      {
        TextView,
        text = "Advance Note Creator",
        textSize = "20sp",
        gravity = "center",
        textColor = "#ffffff",
        padding = "16dp",
        layout_width = "0dp",
        layout_weight = "1"
      },
      {
        Button,
        id = "menuBtn",
        text = "⋮",
        textSize = "28sp",
        background = "#3F51B5",
        textColor = "#ffffff",
        layout_width = "56dp",
        layout_height = "56dp",
        contentDescription = "Menu"
      }
    },
    {
      Spinner,
      id = "categoryFilter",
      layout_width = "match_parent",
      layout_height = "wrap_content",
      prompt = "Filter by Category",
      background = "#ffffff",
      padding = "8dp"
    },
    {
      ListView,
      id = "noteList",
      layout_width = "match_parent",
      layout_height = "0dp",
      layout_weight = "1"
    },
    {
      Button,
      id = "btnAdd",
      text = "+ New Note",
      textSize = "18sp",
      background = "#4CAF50",
      textColor = "#ffffff",
      padding = "16dp",
      layout_width = "match_parent",
      layout_height = "wrap_content"
    }
  }

  activity.setContentView(loadlayout(layout))
  
  local filterAdapter = ArrayAdapter(activity, android.R.layout.simple_spinner_item, categories)
  filterAdapter.setDropDownViewResource(android.R.layout.simple_spinner_dropdown_item)
  categoryFilter.setAdapter(filterAdapter)
  
  function updateList(selectedCategory)
    local items = {}
    for i, note in ipairs(notes) do
      if selectedCategory == "All" or note.category == selectedCategory then
        table.insert(items, note.title)
      end
    end
    local adapter = ArrayAdapter(activity, android.R.layout.simple_list_item_1, items)
    noteList.setAdapter(adapter)
  end
  
  updateList("All")
  
  categoryFilter.onItemSelected = function(parent, view, position, id)
    local selected = categories[position+1]
    updateList(selected)
  end

  noteList.onItemClick = function(l, v, p)
    local selectedCat = categories[categoryFilter.getSelectedItemPosition()+1]
    local filteredNotes = {}
    for i, note in ipairs(notes) do
      if selectedCat == "All" or note.category == selectedCat then
        table.insert(filteredNotes, i)
      end
    end
    local realIndex = filteredNotes[p+1]
    showNoteReadOnly(realIndex)
  end
  
  noteList.setOnItemLongClickListener{
    onItemLongClick = function(parent, view, position, id)
      local selectedCat = categories[categoryFilter.getSelectedItemPosition()+1]
      local filteredNotes = {}
      for i, note in ipairs(notes) do
        if selectedCat == "All" or note.category == selectedCat then
          table.insert(filteredNotes, i)
        end
      end
      local realIndex = filteredNotes[position+1]
      showNoteOptions(realIndex)
      return true
    end
  }

  btnAdd.onClick = function()
    showNewNoteDialog()
  end
  
  menuBtn.onClick = function()
    showMainMenu()
  end
end

