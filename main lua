-- ========== RELIABLE LIST CREATION ==========
function showNewListDialog()
  local dlgBuilder = AlertDialog.Builder(activity)
  dlgBuilder.setTitle("Create Checklist")
  
  local scroll = ScrollView(activity)
  local main = LinearLayout(activity)
  main.setOrientation(LinearLayout.VERTICAL)
  main.setPadding(16, 16, 16, 16)
  
  -- Category spinner
  local catSpinner = Spinner(activity)
  local catList = {}
  for i=2, #categories do table.insert(catList, categories[i]) end
  local catAdapter = ArrayAdapter(activity, android.R.layout.simple_spinner_item, catList)
  catAdapter.setDropDownViewResource(android.R.layout.simple_spinner_dropdown_item)
  catSpinner.setAdapter(catAdapter)
  main.addView(catSpinner)
  
  -- Title input
  local titleEdit = EditText(activity)
  titleEdit.setHint("List Title")
  titleEdit.setTextSize(18)
  main.addView(titleEdit)
  
  -- Label
  local lbl = TextView(activity)
  lbl.setText("Items:")
  lbl.setTextSize(16)
  lbl.setPadding(0, 8, 0, 4)
  main.addView(lbl)
  
  -- Container for dynamic items
  local itemsContainer = LinearLayout(activity)
  itemsContainer.setOrientation(LinearLayout.VERTICAL)
  main.addView(itemsContainer)
  
  local itemEdits = {}
  
  local function addItemRow()
    local row = LinearLayout(activity)
    row.setOrientation(LinearLayout.HORIZONTAL)
    row.setLayoutParams(LinearLayout.LayoutParams(MATCH_PARENT, WRAP_CONTENT))
    row.setPadding(0, 4, 0, 4)
    
    local edit = EditText(activity)
    edit.setHint("Item " .. (#itemEdits + 1))
    edit.setLayoutParams(LinearLayout.LayoutParams(0, WRAP_CONTENT, 1))
    edit.setTextSize(16)
    
    local removeBtn = Button(activity)
    removeBtn.setText("✖")
    removeBtn.setTextSize(18)
    removeBtn.setBackgroundColor(0xFFFF0000)
    removeBtn.setTextColor(0xFFFFFFFF)
    removeBtn.setPadding(8, 4, 8, 4)
    
    row.addView(edit)
    row.addView(removeBtn)
    itemsContainer.addView(row)
    
    local idx = #itemEdits + 1
    table.insert(itemEdits, edit)
    
    removeBtn.onClick = function()
      itemsContainer.removeView(row)
      table.remove(itemEdits, idx)
      for i, ed in ipairs(itemEdits) do
        ed.setHint("Item " .. i)
      end
    end
  end
  
  -- First item
  addItemRow()
  
  -- Add item button
  local addBtn = Button(activity)
  addBtn.setText("+ Add Item")
  addBtn.setBackgroundColor(0xFF4CAF50)
  addBtn.setTextColor(0xFFFFFFFF)
  addBtn.setPadding(12, 8, 12, 8)
  addBtn.onClick = function() addItemRow() end
  main.addView(addBtn)
  
  -- Save button (custom)
  local saveBtn = Button(activity)
  saveBtn.setText("Save List")
  saveBtn.setBackgroundColor(0xFF2196F3)
  saveBtn.setTextColor(0xFFFFFFFF)
  saveBtn.setPadding(12, 8, 12, 8)
  saveBtn.setLayoutParams(LinearLayout.LayoutParams(MATCH_PARENT, WRAP_CONTENT))
  main.addView(saveBtn)
  
  scroll.addView(main)
  dlgBuilder.setView(scroll)
  dlgBuilder.setNegativeButton("Cancel", nil)
  
  local dialog = dlgBuilder.show()
  
  saveBtn.onClick = function()
    local cat = catList[catSpinner.getSelectedItemPosition()+1] or "Other"
    local title = trim(titleEdit.Text)
    if title == "" then
      Toast.makeText(activity, "Please enter a title", 1).show()
      return
    end
    
    local items = {}
    for _, ed in ipairs(itemEdits) do
      local txt = trim(ed.Text)
      if txt ~= "" then
        table.insert(items, txt)
      end
    end
    
    if #items == 0 then
      Toast.makeText(activity, "Please add at least one item", 1).show()
      return
    end
    
    local content = ""
    for i, it in ipairs(items) do
      content = content .. i .. ". " .. it .. "\n"
    end
    
    local time = os.date("%Y-%m-%d %H:%M:%S")
    table.insert(notes, {time = time, category = cat, title = title, content = content})
    saveNotes()
    showMainLayout()
    Toast.makeText(activity, "List saved", 1).show()
    dialog.dismiss()
  end
end
