-- Helper trim function (works on Lua strings)
local function trim(str)
  if str then
    return str:match("^%s*(.-)%s*$")
  end
  return ""
end

local NOTES_FILE = "/sdcard/Download/notes.txt"
local CATEGORIES_FILE = "/sdcard/Download/categories.txt"
local SAVE_FOLDER = "/storage/emulated/0/blind Tech hub/advance note creator"
local notes = {}
local categories = {"All", "Personal", "Work", "Study", "Other", "Shopping", "Ideas", "Important"}

os.execute("mkdir -p " .. SAVE_FOLDER)

local MATCH_PARENT = -1
local WRAP_CONTENT = -2

function loadCategories()
  local file = io.open(CATEGORIES_FILE, "r")
  if file then
    categories = {"All"}
    for line in file:lines() do
      if line ~= "" then
        table.insert(categories, line)
      end
    end
    file:close()
  else
    saveCategories()
  end
end

function saveCategories()
  local file = io.open(CATEGORIES_FILE, "w")
  for i=2, #categories do
    file:write(categories[i] .. "\n")
  end
  file:close()
end

function loadNotes()
  notes = {}
  local file = io.open(NOTES_FILE, "r")
  if file then
    for line in file:lines() do
      local time, category, title, content = line:match("^(.-);(.-);(.-);(.*)$")
      if time and category and title and content then
        table.insert(notes, {time = time, category = category, title = title, content = content})
      end
    end
    file:close()
  end
end

function saveNotes()
  local file = io.open(NOTES_FILE, "w")
  for _, note in ipairs(notes) do
    file:write(note.time .. ";" .. note.category .. ";" .. note.title .. ";" .. note.content .. "\n")
  end
  file:close()
end

function exportSingleNote(note, format, shareAfterSave)
  local fileName = note.title:gsub("[^%w]", "_") .. "_" .. os.time()
  local filePath = SAVE_FOLDER .. "/" .. fileName
  
  local content = ""
  if format == "txt" then
    filePath = filePath .. ".txt"
    content = "Category: " .. note.category .. "\nTitle: " .. note.title .. "\nTime: " .. note.time .. "\nContent:\n" .. note.content
  elseif format == "html" then
    filePath = filePath .. ".html"
    content = [[<html><body><h1>]] .. note.title .. [[</h1><p><b>Category:</b> ]] .. note.category .. [[</p><p><b>Time:</b> ]] .. note.time .. [[</p><p><b>Content:</b><br/>]] .. note.content:gsub("\n", "<br/>") .. [[</p></body></html>]]
  else
    filePath = filePath .. ".md"
    content = "# " .. note.title .. "\n\n**Category:** " .. note.category .. "\n**Time:** " .. note.time .. "\n\n**Content:**\n" .. note.content
  end
  
  local file = io.open(filePath, "w")
  if file then
    file:write(content)
    file:close()
    Toast.makeText(activity, "Saved: " .. filePath, 0).show()
    if shareAfterSave then
      shareFile(filePath)
    end
    return true
  else
    Toast.makeText(activity, "Export failed!", 1).show()
    return false
  end
end

function shareFile(filePath)
  local intent = Intent(Intent.ACTION_SEND)
  intent.setType("text/plain")
  intent.putExtra(Intent.EXTRA_STREAM, Uri.parse("file://" .. filePath))
  activity.startActivity(Intent.createChooser(intent, "Share via"))
end

function showFormatDialog(note, callbackType)
  local formats = {"TXT", "HTML", "MARKDOWN"}
  AlertDialog.Builder(activity)
    .setTitle("Select Export Format")
    .setItems(formats, function(dialog, which)
      local format = "txt"
      if which == 0 then format = "txt"
      elseif which == 1 then format = "html"
      else format = "md" end
      
      if callbackType == "export" then
        exportSingleNote(note, format, false)
      elseif callbackType == "share" then
        exportSingleNote(note, format, true)
      end
    end)
    .show()
end

function exportAllNotes()
  if #notes == 0 then
    Toast.makeText(activity, "No notes to export", 1).show()
    return
  end
  
  local formats = {"TXT", "HTML", "MARKDOWN"}
  AlertDialog.Builder(activity)
    .setTitle("Export All Notes - Select Format")
    .setItems(formats, function(dialog, which)
      local ext = "txt"
      local separator = "\n" .. string.rep("=", 50) .. "\n"
      local allContent = ""
      
      if which == 0 then ext = "txt"
      elseif which == 1 then ext = "html"
      else ext = "md" end
      
      local fileName = "All_Notes_" .. os.date("%Y%m%d_%H%M%S") .. "." .. ext
      local filePath = SAVE_FOLDER .. "/" .. fileName
      
      for i, note in ipairs(notes) do
        if which == 0 then
          allContent = allContent .. "Category: " .. note.category .. "\nTitle: " .. note.title .. "\nTime: " .. note.time .. "\nContent:\n" .. note.content .. separator
        elseif which == 1 then
          allContent = allContent .. [[<hr/><h2>]] .. note.title .. [[</h2><p><b>Category:</b> ]] .. note.category .. [[</p><p><b>Time:</b> ]] .. note.time .. [[</p><p><b>Content:</b><br/>]] .. note.content:gsub("\n", "<br/>") .. [[</p>]]
        else
          allContent = allContent .. "## " .. note.title .. "\n\n**Category:** " .. note.category .. "\n**Time:** " .. note.time .. "\n\n**Content:**\n" .. note.content .. "\n\n---\n\n"
        end
      end
      
      if which == 1 then
        allContent = "<html><body>" .. allContent .. "</body></html>"
      end
      
      local file = io.open(filePath, "w")
      if file then
        file:write(allContent)
        file:close()
        Toast.makeText(activity, "Exported: " .. filePath, 0).show()
        AlertDialog.Builder(activity)
          .setTitle("Export Complete")
          .setMessage("File saved to:\n" .. filePath .. "\n\nShare now?")
          .setPositiveButton("Share", function()
            shareFile(filePath)
          end)
          .setNegativeButton("OK", nil)
          .show()
      else
        Toast.makeText(activity, "Export failed!", 1).show()
      end
    end)
    .show()
end

function deleteAllNotes()
  if #notes == 0 then
    Toast.makeText(activity, "No notes to delete", 1).show()
    return
  end
  
  AlertDialog.Builder(activity)
    .setTitle("Delete All Notes")
    .setMessage("Are you sure you want to delete ALL notes?\nThis action cannot be undone!")
    .setPositiveButton("Yes, Delete All", function()
      notes = {}
      saveNotes()
      showMainLayout()
      Toast.makeText(activity, "All notes deleted", 1).show()
    end)
    .setNegativeButton("Cancel", nil)
    .show()
end

function refreshList()
  loadNotes()
  showMainLayout()
  Toast.makeText(activity, "Refreshed! Total: " .. #notes .. " notes", 0).show()
end

function showMainMenu()
  local menuOptions = {"Export All", "Refresh", "Delete All", "Manage Categories"}
  
  AlertDialog.Builder(activity)
    .setTitle("Menu")
    .setItems(menuOptions, function(dialog, which)
      if which == 0 then
        exportAllNotes()
      elseif which == 1 then
        refreshList()
      elseif which == 2 then
        deleteAllNotes()
      elseif which == 3 then
        manageCategories()
      end
    end)
    .show()
end

function manageCategories()
  local catList = {}
  for i=2, #categories do
    table.insert(catList, categories[i])
  end
  table.insert(catList, "+ Add New Category")
  
  AlertDialog.Builder(activity)
    .setTitle("Manage Categories")
    .setItems(catList, function(dialog, which)
      if which == #catList then
        local input = EditText(activity)
        input.hint = "Enter category name"
        AlertDialog.Builder(activity)
          .setTitle("New Category")
          .setView(input)
          .setPositiveButton("Add", function()
            local newCat = trim(input.Text)
            if newCat ~= "" then
              table.insert(categories, newCat)
              saveCategories()
              Toast.makeText(activity, "Category added", 1).show()
              showMainLayout()
            end
          end)
          .setNegativeButton("Cancel", nil)
          .show()
      else
        local selectedCat = catList[which]
        AlertDialog.Builder(activity)
          .setTitle("Delete Category?")
          .setMessage("Delete '" .. selectedCat .. "'? Notes in this category will become 'Other'.")
          .setPositiveButton("Delete", function()
            for i, note in ipairs(notes) do
              if note.category == selectedCat then
                notes[i].category = "Other"
              end
            end
            for i=2, #categories do
              if categories[i] == selectedCat then
                table.remove(categories, i)
                break
              end
            end
            saveCategories()
            saveNotes()
            showMainLayout()
            Toast.makeText(activity, "Category deleted", 1).show()
          end)
          .setNegativeButton("Cancel", nil)
          .show()
      end
    end)
    .show()
end

function showNoteOptions(index)
  local note = notes[index]
  local options = {"Edit", "Export File", "Share", "Delete"}
  
  AlertDialog.Builder(activity)
    .setTitle("Options for: " .. note.title)
    .setItems(options, function(dialog, which)
      if which == 0 then
        showEditNote(index)
      elseif which == 1 then
        showFormatDialog(note, "export")
      elseif which == 2 then
        showFormatDialog(note, "share")
      elseif which == 3 then
        AlertDialog.Builder(activity)
          .setTitle("Confirm Delete")
          .setMessage("Delete this note?")
          .setPositiveButton("Yes", function()
            table.remove(notes, index)
            saveNotes()
            Toast.makeText(activity, "Note deleted", 1).show()
            showMainLayout()
          end)
          .setNegativeButton("No", nil)
          .show()
      end
    end)
    .show()
end

