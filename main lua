function showEditNote(index)
  local note = notes[index]
  local editLayout = {
    LinearLayout,
    orientation = "vertical",
    padding = "16dp",
    {
      Spinner,
      id = "editCategory",
      layout_width = "match_parent",
      layout_height = "wrap_content"
    },
    {
      EditText,
      id = "editTitle",
      hint = "Title",
      text = note.title,
      layout_width = "match_parent",
      textSize = "18sp"
    },
    {
      EditText,
      id = "editContent",
      hint = "Content",
      text = note.content,
      layout_width = "match_parent",
      layout_height = "200dp",
      gravity = "top",
      textSize = "16sp"
    }
  }
  
  local dialogView = loadlayout(editLayout)
  
  -- Populate categories
  local catList = {}
  for i=2, #categories do
    table.insert(catList, categories[i])
  end
  local adapter = ArrayAdapter(activity, android.R.layout.simple_spinner_item, catList)
  adapter.setDropDownViewResource(android.R.layout.simple_spinner_dropdown_item)
  editCategory.setAdapter(adapter)
  -- Set current category
  for i, cat in ipairs(catList) do
    if cat == note.category then
      editCategory.setSelection(i-1)
      break
    end
  end

  AlertDialog.Builder(activity)
    .setTitle("Edit Note")
    .setView(dialogView)
    .setPositiveButton("Save", function()
      local newCat = catList[editCategory.getSelectedItemPosition()+1]
      local newTitle = editTitle.Text
      local newContent = editContent.Text
      if newTitle ~= "" and newContent ~= "" then
        notes[index].category = newCat
        notes[index].title = newTitle
        notes[index].content = newContent
        saveNotes()
        Toast.makeText(activity, "Note updated", 1).show()
        showMainLayout()
      else
        Toast.makeText(activity, "Fields cannot be empty", 1).show()
      end
    end)
    .setNegativeButton("Cancel", nil)
    .show()
end

